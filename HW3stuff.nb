Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "replacing", " ", "all", " ", "the", " ", "t_BS", " ", "and", " ", "r_BS",
      " ", "with", " ", 
     RowBox[{"1", "/", "sqrt2"}]}], ",", " ", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
     "also", " ", "assuming", " ", "end", " ", "test", " ", "masses", " ", 
      "have", " ", "perfect", " ", "reflectivities", " ", "rx"}], "=", 
     RowBox[{"ry", "=", "1"}]}], ",", " ", 
    RowBox[{
    "and", " ", "assuming", " ", "homodyne", " ", "BS", " ", "is", " ", "a", " ",
      "perfect", " ", 
     RowBox[{"50", "/", "50"}], " ", "for", " ", "simplicity"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"M50", "=", 
     RowBox[{"M", "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"tBS", "->", 
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}]}], ",", 
        RowBox[{"rBS", "->", 
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}]}], ",", 
        RowBox[{"rx", "->", "1"}], ",", 
        RowBox[{"ry", "->", "1"}], ",", " ", 
        RowBox[{"tHD", "->", 
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}]}], ",", " ", 
        RowBox[{"rHD", "->", 
         RowBox[{"1", "/", 
          RowBox[{"Sqrt", "[", "2", "]"}]}]}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "recalculating", " ", "TFs", " ", "with", " ", "these", " ", "t_BS", " ", 
     "and", " ", "r_BS", " ", "subs"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"T50", "=", 
     RowBox[{"Inverse", "[", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"Length", "[", "nodes", "]"}], "]"}], "-", "M50"}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TEPDA", "=", 
     RowBox[{"TF50", "[", 
      RowBox[{"\"\<Ein\>\"", ",", "\"\<EA\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"TEPDB", "=", 
     RowBox[{"TF50", "[", 
      RowBox[{"\"\<Ein\>\"", ",", "\"\<EB\>\""}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "helper", " ", "function", " ", "with", " ", "substituted", " ", 
     "matrix"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TF50", "[", 
     RowBox[{"from_String", ",", "to_String"}], "]"}], ":=", 
    RowBox[{"T50", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{
        RowBox[{"Position", "[", 
         RowBox[{"nodes", ",", "to"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
       RowBox[{
        RowBox[{"Position", "[", 
         RowBox[{"nodes", ",", "from"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "]"}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "replacing", " ", "kLx", " ", "with", " ", "phix", " ", "and", " ", "kLy",
      " ", "with", " ", "phiy"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TEPDA\[Phi]", "=", 
     RowBox[{"TEPDA", "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"k", "*", "Lx"}], "->", "\[Phi]x"}], ",", 
        RowBox[{
         RowBox[{"k", "*", "Ly"}], "->", "\[Phi]y"}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"TEPDB\[Phi]", "=", 
     RowBox[{"TEPDB", "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"k", "*", "Lx"}], "->", "\[Phi]x"}], ",", 
        RowBox[{
         RowBox[{"k", "*", "Ly"}], "->", "\[Phi]y"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "replacing", " ", "phix", " ", "and", " ", "phiy", " ", "with", " ", 
      "appropriate", " ", "phiD", " ", "and", " ", "phiC", " ", 
      "expressions"}], ",", " ", 
     RowBox[{
     "using", " ", "the", " ", "ones", " ", "given", " ", "in", " ", "the", " ",
       "HW", " ", "assignment"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"phaseSub", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Phi]x", "->", 
        RowBox[{"\[Phi]c", "+", "\[Phi]d"}]}], ",", 
       RowBox[{"\[Phi]y", "->", 
        RowBox[{"\[Phi]c", "-", "\[Phi]d"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"TEPDAdc", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"TEPDA\[Phi]", "/.", " ", "phaseSub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"TEPDBdc", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"TEPDB\[Phi]", "/.", " ", "phaseSub"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"Row", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<E_PDA/E_in = \>\"", ",", "TEPDAdc"}], "}"}], "]"}], "\n", 
   RowBox[{"Row", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<E_PDB/E_in = \>\"", ",", "TEPDBdc"}], "}"}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"PPDA", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"TEPDAdc", "*", 
       RowBox[{"Conjugate", "[", "TEPDAdc", "]"}]}], "]"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"PPDB", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"TEPDBdc", "*", 
       RowBox[{"Conjugate", "[", "TEPDBdc", "]"}]}], "]"}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Using", " ", "P"}], " ", "=", " ", 
      RowBox[{"|", "E", "|", 
       RowBox[{"^", "2"}]}]}], ",", " ", 
     RowBox[{"finding", " ", "power", " ", "transfer", " ", "functions"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<P_PDA/P_in = \>\"", ",", "PPDA"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<P_PDB/P_in = \>\"", ",", "PPDB"}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.982019403769844*^9, 3.982019431817546*^9}, {
  3.9820194627157907`*^9, 3.9820195362678013`*^9}, {3.9820196009367332`*^9, 
